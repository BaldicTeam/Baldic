<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>netstandard2.0</TargetFramework>
    <AssemblyName>Baldic.API.Resources</AssemblyName>
    <RootNamespace>Baldic.API.Resources</RootNamespace>
    <Description>Baldic resource API: textures, sprites, audio, AssetBundles, localization. Requires Unity managed assemblies at runtime.</Description>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\Baldic.Loader.Abstractions\Baldic.Loader.Abstractions.csproj" />
    <ProjectReference Include="..\Baldic.API.Core\Baldic.API.Core.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Newtonsoft.Json" Version="13.0.3" />
    <!--
      UnityEngine assemblies are referenced from the local game installation.
      Add them via game-references.props (generated by `baldic game set`).
      They are intentionally NOT shipped with Baldic — see sec. 12.4 of the plan.
    -->
  </ItemGroup>
</Project>
